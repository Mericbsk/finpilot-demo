# FinPilot Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# === Authentication (REQUIRED) ===
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FINPILOT_SECRET_KEY=your_64_character_hex_secret_here

# === LLM API Keys ===
GROQ_API_KEY=your_groq_api_key_here
GOOGLE_API_KEY=your_google_gemini_api_key_here

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# === Data Providers (Optional) ===
POLYGON_API_KEY=your_polygon_api_key_here
NEWS_API_KEY=your_news_api_key_here

# === MLflow (Optional) ===
MLFLOW_TRACKING_URI=http://localhost:5000

# === Langfuse LLM Observability (Optional) ===
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# === Redis Cache (Optional) ===
REDIS_URL=redis://localhost:6379/0

# === Alpaca Paper Trading (Sprint 21) ===
ALPACA_API_KEY=your_alpaca_paper_api_key_here
ALPACA_SECRET_KEY=your_alpaca_paper_secret_key_here

# === Database (Sprint 22) ===
# Default: SQLite (no config needed, uses data/finpilot.db)
# For PostgreSQL: uncomment below and run: docker-compose --profile db up -d
# DATABASE_URL=postgresql://finpilot:finpilot_dev_2026@localhost:5432/finpilot  # pragma: allowlist secret
# POSTGRES_PASSWORD=finpilot_dev_2026  # pragma: allowlist secret
