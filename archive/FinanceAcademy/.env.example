# Finance Academy — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyala: cp .env.example .env

# DB dosyasının nereye yazılacağı (varsayılan: FinanceAcademy/data/academy.db)
# Kendi bilgisayarında bu satırı yoruma al, varsayılan çalışır.
# ACADEMY_DB_PATH=./data/academy.db

# LLM (Groq) — içerik üretimi için zorunlu
# Borsa projesinin .env dosyasındaki GROQ_API_KEY ile aynı
GROQ_API_KEY=your_groq_api_key_here
