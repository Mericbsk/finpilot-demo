# Normalize line endings — prevents 'LF will be replaced by CRLF' warnings on Windows.
* text=auto eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.db binary
*.sqlite binary
*.sqlite3 binary
*.pkl binary
*.pyc binary
*.so binary
*.dll binary

# Shell scripts must stay LF
*.sh text eol=lf
Makefile text eol=lf

# Windows-specific
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
